  <script>
    // ===== THREE.JS 3D CITY OPTIMIZADO =====
    function initThreeJS() {
      const canvas = document.getElementById('three-bg');
      if (!canvas) return;
      
      if (typeof THREE === 'undefined') {
        console.log('Three.js no cargó');
        return;
      }

      try {
        const scene = new THREE.Scene();
        scene.background = new THREE.Color(0xfafaf8);
        scene.fog = new THREE.Fog(0xfafaf8, 30, 70);
        
        const camera = new THREE.PerspectiveCamera(75, window.innerWidth / window.innerHeight, 0.1, 1000);
        const renderer = new THREE.WebGLRenderer({ 
          canvas: canvas, 
          alpha: true, 
          antialias: false,
          powerPreference: 'low-power'
        });
        
        renderer.setSize(window.innerWidth, window.innerHeight);
        renderer.setPixelRatio(Math.min(window.devicePixelRatio, 1.5));

        const buildingColors = [0x6ee78a, 0x4ade80, 0x2d9d4c, 0x1a7a3a];
        const allObjects = [];

        function createBuilding() {
          const height = 5 + Math.random() * 12;
          const width = 3 + Math.random() * 3;
          const depth = 3 + Math.random() * 3;
          
          const buildingGeo = new THREE.BoxGeometry(width, height, depth);
          const buildingMat = new THREE.MeshPhongMaterial({
            color: buildingColors[Math.floor(Math.random() * buildingColors.length)],
            shininess: 30
          });
          
          const building = new THREE.Mesh(buildingGeo, buildingMat);
          building.position.x = (Math.random() - 0.5) * 60;
          building.position.y = (Math.random() - 0.5) * 40;
          building.position.z = -60 - Math.random() * 30;
          
          scene.add(building);
          
          return {
            mesh: building,
            speed: 0.4 + Math.random() * 0.3,
            rotationSpeed: (Math.random() - 0.5) * 0.015
          };
        }

        for (let i = 0; i < 20; i++) {
          allObjects.push(createBuilding());
        }

        function createEnergySphere() {
          const sphereGeo = new THREE.SphereGeometry(2, 12, 12);
          const sphereMat = new THREE.MeshPhongMaterial({
            color: 0x4ade80,
            transparent: true,
            opacity: 0.5,
            shininess: 50
          });
          
          const sphere = new THREE.Mesh(sphereGeo, sphereMat);
          sphere.position.x = (Math.random() - 0.5) * 60;
          sphere.position.y = (Math.random() - 0.5) * 40;
          sphere.position.z = -60 - Math.random() * 30;
          
          scene.add(sphere);
          
          return {
            mesh: sphere,
            speed: 0.6 + Math.random() * 0.2,
            rotationSpeed: (Math.random() - 0.5) * 0.03
          };
        }

        for (let i = 0; i < 5; i++) {
          allObjects.push(createEnergySphere());
        }

        const gridHelper = new THREE.GridHelper(150, 50, 0x2d9d4c, 0x1a7a3a);
        gridHelper.position.y = -30;
        gridHelper.material.opacity = 0.2;
        gridHelper.material.transparent = true;
        scene.add(gridHelper);

        const ambient = new THREE.AmbientLight(0xffffff, 0.6);
        scene.add(ambient);

        const dirLight = new THREE.DirectionalLight(0xffffff, 0.7);
        dirLight.position.set(10, 20, 10);
        scene.add(dirLight);

        camera.position.z = 10;
        camera.position.y = 3;

        let time = 0;

        function animate() {
          requestAnimationFrame(animate);
          time += 0.015;

          allObjects.forEach(obj => {
            obj.mesh.position.z += obj.speed;
            obj.mesh.rotation.y += obj.rotationSpeed;
            
            if (obj.mesh.position.z > 15) {
              obj.mesh.position.z = -90;
              obj.mesh.position.x = (Math.random() - 0.5) * 60;
              obj.mesh.position.y = (Math.random() - 0.5) * 40;
            }
          });

          gridHelper.position.z = (time * 10) % 3;

          camera.position.x = Math.sin(time * 0.2) * 3;
          camera.position.y = 3 + Math.cos(time * 0.15) * 2;
          camera.lookAt(0, 0, -10);

          renderer.render(scene, camera);
        }

        animate();

        window.addEventListener('resize', () => {
          camera.aspect = window.innerWidth / window.innerHeight;
          camera.updateProjectionMatrix();
          renderer.setSize(window.innerWidth, window.innerHeight);
        });
      } catch (error) {
        console.log('Error en Three.js:', error);
      }
    }

    setTimeout(initThreeJS, 100);
  </script>
